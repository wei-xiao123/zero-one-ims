    "@wangeditor/editor-for-vue": "^5.1.12",
    "ag-grid-community": "^34.3.0",
    "ag-grid-vue3": "^34.3.0",
    "axios": "^1.7.2",
    "crypto-js": "^4.2.0",
    "echarts": "^5.5.0",
    "element-plus": "^2.9.7",
