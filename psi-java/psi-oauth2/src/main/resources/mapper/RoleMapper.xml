<?xml version="1.0" encoding="UTF-8"?><!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zeroone.star.oauth2.mapper.RoleMapper">
    <resultMap id="BaseResultMap" type="com.zeroone.star.oauth2.entity.Role">
        <id column="id" jdbcType="VARCHAR" property="id" />
        <result column="name" jdbcType="VARCHAR" property="name" />
        <result column="data" jdbcType="VARCHAR" property="data" />
        <result column="root" jdbcType="VARCHAR" property="root" />
        <result column="auth" jdbcType="VARCHAR" property="auth" />
        <result column="keyword" jdbcType="VARCHAR" property="keyword" />
    </resultMap>
    <select id="selectByUserId" resultMap="BaseResultMap">
      select r.id,r.`name`,r.data,r.root,r.auth,r.`keyword`
      from user u
      join role r on r.id=u.role
      where u.id = #{userId}
    </select>
<!--    <select id="selectByMenuPath" resultMap="BaseResultMap">-->
<!--      select id,keyword from role where id in (select role_id from role_menu where menu_id=(select id from menu where link_url=#{path}))-->
<!--    </select>-->



    <select id="selectIdAndUrl" resultType="com.zeroone.star.oauth2.entity.FunIdAndUrl">
        SELECT id,url
        FROM func_perm
        WHERE
        is_enable = '1'
    </select>
</mapper>
