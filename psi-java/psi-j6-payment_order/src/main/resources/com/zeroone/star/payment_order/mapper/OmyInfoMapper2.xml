<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zeroone.star.payment_order.mapper.OmyInfoMapper2">
    <!-- 根据pid查询详情列表 -->
    <select id="selectByPid" parameterType="string" resultType="com.zeroone.star.payment_order.entity.OmyInfoDO">
        select id, pid, account, money, settle, data
        from omy_info
        where pid = #{pid}
    </select>
</mapper>