<?xml version="1.0" encoding="UTF-8"?><!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zeroone.star.storemanagement.mapper.OtherInMapper">

    <insert id="insert">
        insert into entry(id, supplier,frame,time,number,type,total,cost,people,logistics,file,data,more,examine,cse,`check`,`user`)
        values(#{id},#{supplier},#{frame},#{time},#{number},#{type},#{total},#{cost},#{people},#{logistics},#{file},#{data},#{more},#{examine},#{cse},#{check},#{user})
    </insert>

    <update id="update">
        update entry set supplier=#{supplier},frame=#{frame},time=#{time},number=#{number},
        type=#{type},total=#{total},cost=#{cost},people=#{people},logistics=#{logistics},file=#{file},
        data=#{data},examine=#{examine},cse=#{cse},`check`=#{check},user=#{user}
        where id=#{id}
    </update>
    <update id="updateExamine">
        update entry set examine=#{status} where id in
        <foreach item="item" collection="ids" separator="," open="(" close=")">
            #{item}
        </foreach>
    </update>
    <update id="updateCheck">
        update entry set `check`=#{status} where id in
        <foreach item="item" collection="ids" separator="," open="(" close=")">
            #{item}
        </foreach>
    </update>

    <delete id="deleteById">
        DELETE FROM entry WHERE id = #{id};
    </delete>

    <select id="getExamineByIds" resultType="java.lang.Integer">
        select examine from entry where id in
        <foreach item="item" collection="ids" separator="," open="(" close=")">
            #{item}
        </foreach>
    </select>
    <select id="getCheckByIds" resultType="java.lang.Integer">
        select `check` from entry where id in
        <foreach item="item" collection="ids" separator="," open="(" close=")">
            #{item}
        </foreach>
    </select>
    <select id="getByIds" resultType="com.zeroone.star.storemanagement.entity.EntryDO">
        select id, supplier, frame, time, number, type, total, cost, people, logistics, file, data, more, examine, cse, `check`, user
        from entry where id in
        <foreach item="item" collection="ids" separator="," open="(" close=")">
            #{item}
        </foreach>
    </select>

    <select id="selectById" resultType="com.zeroone.star.storemanagement.entity.EntryDO">
        select id, supplier, frame, time, number, type, total, cost, people, logistics, file, data, more, examine, cse, `check`, `user`
        from entry where id = #{id}
    </select>

    <select id="selectBatchIds" resultType="com.zeroone.star.storemanagement.entity.EntryDO">
        select id, supplier, frame, time, number, type, total, cost, people, logistics, file, data, more, examine, cse, `check`, `user`
        from entry where id in
        <foreach item="item" collection="ids" separator="," open="(" close=")">
            #{item}
        </foreach>
    </select>


</mapper>
