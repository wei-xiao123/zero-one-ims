<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zeroone.star.storemanagement.mapper.GoodsMapper">
    <!--用来查询goods表中是否已经存在该数据，存在则返回id-->
    <select id="selectGoods"
            parameterType=
                    "com.zeroone.star.storemanagement.entity.GoodsDO"
            resultType="java.lang.String">
        SELECT id FROM goods t WHERE
                t.name = #{goodsDO.name}
            AND t.number = #{goodsDO.number}
            <if test="goodsDO.spec != null and goodsDO.spec != ''">
                AND t.spec = #{goodsDO.spec}
            </if>
    </select>

    <!--goods表的key字段-->
    <sql id="key">
        <trim suffixOverrides=",">
            <if test="name != null and name != ''">name,</if>
            <if test="number != null and number != ''">number,</if>
            <if test="spec != null and spec != ''">spec,</if>
            id,
            py,
            category,
            unit,
            buy,
            sell,
            stock,
            type,
            more
        </trim>
    </sql>
    <!--插入goods表的value字段-->
    <sql id="value">
        <trim suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
            <if test="number != null and number != ''">#{number},</if>
            <if test="spec != null and spec != ''">#{spec},</if>
            #{id},
            #{py},
            #{category},
            #{unit},
            #{buy},
            #{sell},
            #{stock},
            #{type},
            #{more}
        </trim>
    </sql>
    <insert id="insertGoods"
            parameterType="com.zeroone.star.storemanagement.entity.GoodsDO"
        >
        INSERT INTO goods
        (<include refid="key"/>)
        VALUES
        (<include refid="value"/>)
    </insert>
</mapper>